{
  "name": "hoify",
  "private": true,
  "scripts": {
    "lint": "cd hoify-server && npm run lint",
    "lint:fix": "cd hoify-server && npm run lint:fix",
    "lint:frontend": "cd frontend && npm run lint",
    "postinstall": "cd hoify-server && npm install && cd ../frontend && npm install",
    "prepare": "husky"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "husky": "^9.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lint-staged": "^17.0.0",
    "ts-jest": "^29.4.11"
  },
  "lint-staged": {
    "hoify-server/src/**/*.ts": [
      "eslint --fix",
      "eslint"
    ]
  }
}
