{
  "name": "hoify",
  "private": true,
  "scripts": {
    "lint": "cd hoify-server && npm run lint",
    "lint:fix": "cd hoify-server && npm run lint:fix",
    "lint:frontend": "cd frontend && npm run lint",
    "postinstall": "cd hoify-server && npm install && cd ../frontend && npm install",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "lint-staged": "^17.0.0"
  },
  "lint-staged": {
    "hoify-server/src/**/*.ts": [
      "eslint --fix",
      "eslint"
    ]
  }
}
