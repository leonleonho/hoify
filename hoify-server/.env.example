# PostgreSQL
POSTGRES_USER=hoify
POSTGRES_PASSWORD=hoify_dev
POSTGRES_DB=hoify
POSTGRES_PORT=5432

# Application
DATABASE_URL=postgresql://hoify:hoify_dev@localhost:5432/hoify
PORT=4000
JWT_SECRET=dev-secret-change-in-production
MUSIC_LIBRARY_PATH=./music
ALBUM_ART_PATH=./album-art

# Redis
REDIS_URL=redis://localhost:6379/0

# Beets ingest (optional — path where raw music files are dropped for automatic tagging + organization)
# BEETS_INGEST_PATH=./ingest

# Enrichment
# ENRICHMENT_CONCURRENCY=5  (default: 5)

# AcoustID + MusicBrainz (optional — identifies tracks with missing metadata)
# Get API key at https://acoustid.org/register
# ACOUSTID_API_KEY=your_key_here
# MUSICBRAINZ_USER_AGENT=Hoify/0.1.0 (https://github.com/your-org/hoify)

# Logging
# LOG_LEVEL=trace|debug|info|warn|error|silent  (defaults: debug in dev, warn in prod)