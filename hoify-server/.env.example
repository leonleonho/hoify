# PostgreSQL
POSTGRES_USER=hoify
POSTGRES_PASSWORD=hoify_dev
POSTGRES_DB=hoify
POSTGRES_PORT=5432

# Application
DATABASE_URL=postgresql://hoify:hoify_dev@localhost:5432/hoify
PORT=4000
JWT_SECRET=dev-secret-change-in-production
MUSIC_LIBRARY_PATH=./music

# Redis
REDIS_URL=redis://localhost:6379/0

# Enrichment
# ENRICHMENT_CONCURRENCY=5  (default: 5)

# Logging
# LOG_LEVEL=trace|debug|info|warn|error|silent  (defaults: debug in dev, warn in prod)