{
  "name": "hoify-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && rsync -am --include='*.graphql' --include='*/' --exclude='*' src/ dist/",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@apollo/server": "^4.12.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "graphql": "^16.10.0",
    "graphql-tag": "^2.12.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^22.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}